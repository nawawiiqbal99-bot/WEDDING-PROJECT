<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* Container untuk background slideshow */
        .bg-slideshow {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            overflow: hidden;
        }

        /* Elemen gambar individual */
        .bg-slide {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-size: cover;
            background-position: center;
            opacity: 0;
            transition: opacity 1.5s ease-in-out, transform 8s ease-in-out;
            transform: scale(1);
        }

        /* Kelas untuk foto yang sedang aktif */
        .bg-slide.active {
            opacity: 1;
            transform: scale(1.05); /* Efek zoom perlahan agar terkesan hidup */
        }

        /* Overlay gelap agar teks di atasnya tetap mudah dibaca */
        .bg-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.6);
            z-index: -1;
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4 font-sans text-slate-800 relative">

    <!-- LAYER BACKGROUND SLIDESHOW -->
    <div class="bg-slideshow" id="slideshowContainer">
        <!-- Foto-foto akan dimuat otomatis via JavaScript di bawah -->
    </div>
    <!-- Layer Kegelapan untuk Menjaga Keterbacaan Teks -->
    <div class="bg-overlay"></div>

    <!-- CARD UTAMA -->
    <div class="bg-white/90 backdrop-blur-md p-8 rounded-2xl shadow-2xl w-full max-w-md border border-amber-200/50 text-center relative z-10">
        <p class="text-amber-600 font-semibold tracking-widest text-xs uppercase mb-2">Pengecekan Undangan Pernikahan</p>
        <h1 class="text-3xl font-serif font-bold text-slate-900 mb-1">Nawawi Iqbal</h1>
        <p class="text-amber-700 italic font-medium my-1">&</p>
        <h1 class="text-3xl font-serif font-bold text-slate-900 mb-6">Zikratul Aini</h1>
        
        <hr class="border-amber-200/80 my-4">

        <div class="mb-6 text-left">
            <label class="block text-sm font-medium text-slate-700 mb-2">Masukkan Nama Anda:</label>
            <input type="text" id="inputNama" placeholder="Contoh: Budi Santoso" 
                   class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-amber-500 bg-white/80">
            <button onclick="prosesCek()" id="btnCek"
                    class="w-full mt-3 bg-amber-600 hover:bg-amber-700 text-white font-semibold py-3 px-4 rounded-xl shadow-md transition-colors">
                Cek Status Undangan
            </button>
        </div>

        <div id="resultArea" class="hidden p-4 rounded-xl text-left border transition-all">
            <p class="text-xs uppercase tracking-wider text-slate-500 mb-1">Status Tamu:</p>
            <h3 id="resNama" class="text-xl font-bold text-slate-900 mb-1">-</h3>
            <span id="resStatus" class="inline-block px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wide mb-3">-</span>
            <p id="resMessage" class="text-sm text-slate-600 border-t border-slate-100 pt-2">-</p>
        </div>
    </div>

    <script>
        // =========================================================
        // TEMPAT SELIPKAN LINK FOTO GOOGLE DRIVE ANDA DI SINI
        // Format link Direct Google Drive: https://lh3.googleusercontent.com/d/ID_FOTO_ANDA
        // =========================================================
        const fotoBackground = [
            "https://lh3.googleusercontent.com/d/1q-kb-AhcOJwjmeH_-jszY-uL9hTba0zP",
            "https://lh3.googleusercontent.com/d/1SMEpH0GLfWeL3NTMtRTBPPqu2noahlDZ",
            "https://lh3.googleusercontent.com/d/1JD0ja3uVTQPo9A9zYZfWen2jq3EJpq7x"
            // Tambahkan foto lain di sini dipisahkan koma
        ];

        // Durasi ganti foto (dalam milidetik) -> 5000 = 5 detik
        const durasiSlide = 5000; 

        // Fungsi Memuat Slide Background
        function initSlideshow() {
            const container = document.getElementById('slideshowContainer');
            
            fotoBackground.forEach((url, index) => {
                const slide = document.createElement('div');
                slide.className = `bg-slide ${index === 0 ? 'active' : ''}`;
                slide.style.backgroundImage = `url('${url}')`;
                container.appendChild(slide);
            });

            let currentIndex = 0;
            const slides = document.querySelectorAll('.bg-slide');

            if (slides.length > 1) {
                setInterval(() => {
                    slides[currentIndex].classList.remove('active');
                    currentIndex = (currentIndex + 1) % slides.length;
                    slides[currentIndex].classList.add('active');
                }, durasiSlide);
            }
        }

        // Jalankan Slideshow saat halaman selesai dimuat
        document.addEventListener("DOMContentLoaded", initSlideshow);

        // Fungsi Cek Tamu dari Apps Script
        function prosesCek() {
            var nama = document.getElementById('inputNama').value.trim();
            var btn = document.getElementById('btnCek');
            var resultArea = document.getElementById('resultArea');
            var resNama = document.getElementById('resNama');
            var resStatus = document.getElementById('resStatus');
            var resMessage = document.getElementById('resMessage');

            if (!nama) {
                alert('Silakan masukkan nama terlebih dahulu.');
                return;
            }

            btn.disabled = true;
            btn.innerText = "Mencari...";
            resultArea.classList.remove('hidden');
            resultArea.className = "p-4 rounded-xl text-left border bg-slate-50 border-slate-200 block";
            resNama.innerText = "Mencari data...";
            resStatus.classList.add('hidden');
            resMessage.innerText = "Mohon tunggu sebentar...";

            google.script.run.withSuccessHandler(function(res) {
                btn.disabled = false;
                btn.innerText = "Cek Status Undangan";

                if (res.found) {
                    resNama.innerText = res.nama;
                    resStatus.innerText = res.status;
                    resStatus.classList.remove('hidden');

                    if (res.status === 'VIP') {
                        resultArea.className = "p-4 rounded-xl text-left border bg-amber-50 border-amber-300 block";
                        resStatus.className = "inline-block px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wide mb-3 bg-amber-600 text-white";
                        resMessage.innerText = "Selamat Datang! Anda berada di area VIP. Silakan tunjukkan layar ini kepada petugas penerima tamu.";
                    } else {
                        resultArea.className = "p-4 rounded-xl text-left border bg-blue-50 border-blue-300 block";
                        resStatus.className = "inline-block px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wide mb-3 bg-blue-600 text-white";
                        resMessage.innerText = "Selamat Datang! Anda terdaftar sebagai tamu REGULER. Terima kasih atas kehadiran Anda.";
                    }
                } else {
                    resultArea.className = "p-4 rounded-xl text-left border bg-red-50 border-red-300 block";
                    resNama.innerText = "Nama Tidak Ditemukan";
                    resStatus.classList.add('hidden');
                    resMessage.innerText = "Maaf, nama Anda tidak terdaftar di sistem. Mohon periksa kembali ejaan nama Anda.";
                }
            }).cekTamu(nama);
        }
    </script>
</body>
</html>
